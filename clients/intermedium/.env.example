# Colyseus WebSocket / HTTP base (dev often proxies from Vite; set full URL if needed)
VITE_COLYSEUS_URL=ws://127.0.0.1:8787

# World API (map topology, `?format=gram`)
VITE_WORLD_API_URL=http://127.0.0.1:8787

# Ghost house (A2A, catalog, conversation)
VITE_GHOST_HOUSE_URL=http://127.0.0.1:3030
# Optional: bearer for `GET /v1/catalog` and conversation routes when the house requires auth
# VITE_GHOST_HOUSE_BEARER=

# Map id for `GET /maps/:mapId?format=gram`
VITE_MAP_ID=sandbox

# Optional: ghost id for paired flows (`?ghost=` also supported)
VITE_DEV_GHOST_ID=
