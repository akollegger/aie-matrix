# Copy to `.env` (gitignored). Loaded from the repo root by:
#   - Node: server + ghosts (via @aie-matrix/root-env) at process startup
#   - Vite (client/phaser): envDir points here — only `VITE_*` keys are exposed to the browser bundle

# --- Game server ---
# AIE_MATRIX_HTTP_PORT=8787
# AIE_MATRIX_MAP=maps/sandbox/freeplay.tmj   # also controls the Phaser client map
# AIE_MATRIX_DEBUG=true
# Movement rules (Gram). When set: authored mode (allow-list enforced). When absent: permissive.
# AIE_MATRIX_RULES=maps/sandbox/green-trap.rules.gram

# --- Ghost house A2A (009) + random-agent — loaded from repo root by @aie-matrix/root-env ---
# Required for @aie-matrix/ghost-house and @aie-matrix/random-agent:
# GHOST_HOUSE_DEV_TOKEN=dev-secret-change-me
# GHOST_HOUSE_PORT=4000
# GHOST_HOUSE_URL=http://127.0.0.1:4000
# CATALOG_FILE_PATH=./catalog.json
# AIE_MATRIX_HTTP_BASE_URL=http://127.0.0.1:8787
#   (house Colyseus bridge + /spectator/room; not the Streamable MCP URL)
# Per-session world MCP URL still comes from registry /adopt (credential.worldApiBaseUrl).
# AGENT_PORT=4001
# RANDOM_AGENT_MOVE_MS=2000
# Optional: GHOST_HOUSE_PUBLIC_BASE_URL, RANDOM_AGENT_PUBLIC_BASE_URL (public HTTP bases for cards/URLs)
# Optional: OTEL_EXPORTER_OTLP_ENDPOINT (enables telemetry.otlp in house capability manifest)
# Optional: GHOST_HOUSE_DISABLE_COLYSEUS_BRIDGE, GHOST_SPECTATOR_ROOM_ID

# --- Ghost random-house (legacy PoC; prefer ghost-house + random-agent above) ---
# AIE_MATRIX_REGISTRY_BASE=http://127.0.0.1:8787
# AIE_MATRIX_WALK_INTERVAL_MS=1500

# --- Phaser (Vite; must be prefixed with VITE_) ---
# VITE_SERVER_HTTP=http://127.0.0.1:8787
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8787
# VITE_SPECTATOR_DEBUG=true

# --- Spectator debug panel (read-only access to /threads) ---
# Set once here; the game server and the Vite client both read this same var.
# SPECTATOR_DEBUG_TOKEN=change-me
