# Copy to `.env` (gitignored). Loaded from the repo root by:
#   - Node: server + ghosts (via @aie-matrix/root-env) at process startup
#   - Vite (client/phaser): envDir points here — only `VITE_*` keys are exposed to the browser bundle

# --- Game server ---
# AIE_MATRIX_HTTP_PORT=8787
# AIE_MATRIX_MAP=maps/sandbox/freeplay.tmj   # also controls the Phaser client map
# AIE_MATRIX_DEBUG=true
# Movement rules (Gram). When set: authored mode (allow-list enforced). When absent: permissive.
# AIE_MATRIX_RULES=maps/sandbox/green-trap.rules.gram

# --- Ghost random-house ---
# AIE_MATRIX_REGISTRY_BASE=http://127.0.0.1:8787
# AIE_MATRIX_WALK_INTERVAL_MS=1500

# --- Phaser (Vite; must be prefixed with VITE_) ---
# VITE_SERVER_HTTP=http://127.0.0.1:8787
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8787
# VITE_SPECTATOR_DEBUG=true
