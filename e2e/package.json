{
  "name": "@aie-matrix/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:browsers": "playwright install chromium",
    "test": "pnpm run install:browsers && E2E_AUTOSTART=1 playwright test",
    "test:manual": "pnpm run install:browsers && playwright test",
    "test:autostart": "pnpm run install:browsers && E2E_AUTOSTART=1 playwright test",
    "test:ui": "pnpm run install:browsers && playwright test --ui",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.12.2",
    "typescript": "~5.7.3"
  }
}
