# Copy key/value lines into the repo *root* `.env` — @aie-matrix/root-env loads the monorepo root.

# Same shared dev token the house uses for A2A/MCP to this agent.
GHOST_HOUSE_DEV_TOKEN=dev-secret-change-me

# Public URL of the ghost house (no trailing path).
GHOST_HOUSE_URL=http://127.0.0.1:4000

# This agent’s HTTP + JSON-RPC A2A server.
AGENT_PORT=4001

# Public base advertised on the agent card. Defaults to http://127.0.0.1:{AGENT_PORT}
# RANDOM_AGENT_PUBLIC_BASE_URL=http://127.0.0.1:4001

# Milliseconds between random moves.
RANDOM_AGENT_MOVE_MS=2000
