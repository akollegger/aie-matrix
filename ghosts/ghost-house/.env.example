# Static bearer for catalog + session control routes (localhost only; see IC-002).
GHOST_HOUSE_DEV_TOKEN=dev-secret-change-me

# Port for the ghost house HTTP server.
GHOST_HOUSE_PORT=4000

# World server MCP (Streamable HTTP), e.g. same host:port as combined server + /mcp
WORLD_API_BASE_URL=http://127.0.0.1:8787/mcp

# File path for the agent catalog JSON.
CATALOG_FILE_PATH=./catalog.json
