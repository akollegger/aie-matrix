# Copy key/value lines into the repo *root* `.env` (or `.env.local`) — @aie-matrix/root-env loads
# the monorepo root, not this file by default.

# Static bearer for catalog + session control routes (localhost only; see IC-002).
GHOST_HOUSE_DEV_TOKEN=dev-secret-change-me

# Port for the ghost house HTTP server.
GHOST_HOUSE_PORT=4000

# Public base for the house’s own URLs (agent card, session APIs). Falls back to http://127.0.0.1:{GHOST_HOUSE_PORT}
# GHOST_HOUSE_PUBLIC_BASE_URL=http://127.0.0.1:4000

# Combined world HTTP *origin* (no /mcp): Colyseus bridge uses this for /spectator/room and the WS URL.
# (Per-spawn Streamable MCP forwarding uses credential.worldApiBaseUrl from registry /adopt, not this var.)
AIE_MATRIX_HTTP_BASE_URL=http://127.0.0.1:8787

# File path for the agent catalog JSON (relative to the process working directory if not absolute).
CATALOG_FILE_PATH=./catalog.json

# Optional: expose telemetry.otlp in the house capability manifest when set
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional Colyseus bridge overrides (see main.ts)
# GHOST_HOUSE_DISABLE_COLYSEUS_BRIDGE=
# GHOST_SPECTATOR_ROOM_ID=

# Supervision (US4) — see SupervisorService readSupervisionConfig
# GHOST_HOUSE_HEALTH_INTERVAL_MS=30000
# GHOST_HOUSE_HEALTH_TIMEOUT_MS=30000
# GHOST_HOUSE_RESTART_BASE_MS=5000
# GHOST_HOUSE_MAX_RESTARTS_PER_HOUR=5
# GHOST_HOUSE_MAX_ACTIONS_PER_MIN=60
# GHOST_HOUSE_SHUTDOWN_GRACE_MS=10000
