{
  "name": "@aie-matrix/ghost-house",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --dir tests/integration"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@aie-matrix/ghost-ts-client": "workspace:*",
    "@aie-matrix/root-env": "workspace:*",
    "@colyseus/core": "0.15.57",
    "colyseus.js": "0.15.28",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.0",
    "express": "^4.21.2",
    "h3-js": "^4.1.0",
    "ulid": "^2.3.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.2",
    "tsx": "^4.19.4",
    "typescript": "~5.7.3",
    "vitest": "^3.2.4"
  }
}
