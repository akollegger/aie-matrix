{
  "name": "aie-matrix",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "@colyseus/core": "0.15.57"
    }
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm run -r --if-present lint",
    "dev": "pnpm --filter @aie-matrix/server dev",
    "server": "pnpm --filter @aie-matrix/server start",
    "server:dev": "pnpm --filter @aie-matrix/server dev",
    "spectator": "pnpm --filter @aie-matrix/client-phaser dev",
    "ghost:house": "pnpm --filter @aie-matrix/ghost-house dev",
    "ghost:register": "node scripts/register-ghost.mjs",
    "ghost:cli": "pnpm --filter @aie-matrix/ghost-cli start",
    "demo": "node scripts/demo.mjs",
    "ports": "node scripts/kill-poc-ports.mjs",
    "ports:kill": "node scripts/kill-poc-ports.mjs --kill",
    "test:e2e": "pnpm --filter @aie-matrix/e2e test",
    "test:e2e:autostart": "pnpm run test:e2e",
    "test:tck": "pnpm --filter @aie-matrix/ghost-tck test"
  },
  "dependencies": {
    "@aie-matrix/root-env": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~5.7.3"
  }
}
