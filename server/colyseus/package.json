{
  "name": "@aie-matrix/server-colyseus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./room-schema": {
      "types": "./dist/room-schema.d.ts",
      "import": "./dist/room-schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aie-matrix/root-env": "workspace:*",
    "@aie-matrix/shared-types": "workspace:*",
    "@colyseus/core": "0.15.57",
    "@colyseus/schema": "2.0.35",
    "@colyseus/ws-transport": "0.15.2",
    "fast-xml-parser": "4.5.5"
  }
}
