{
  "name": "@aie-matrix/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Combined PoC dev process (Colyseus, world-api, registry, auth). Wire scripts per RFC-0001.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "predev": "tsc --build tsconfig.json",
    "prestart": "tsc --build tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@aie-matrix/root-env": "workspace:*",
    "@aie-matrix/server-auth": "workspace:*",
    "@aie-matrix/server-colyseus": "workspace:*",
    "@aie-matrix/server-registry": "workspace:*",
    "@aie-matrix/server-world-api": "workspace:*",
    "@colyseus/core": "0.15.57",
    "@colyseus/ws-transport": "0.15.2",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0"
  }
}
